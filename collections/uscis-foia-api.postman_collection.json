        {
          "id": "fe1355cc-991f-4d25-a4ee-a79ad8ad6cdd",
          "name": "Submit FOIA or Privacy Act Request",
          "request": {
            "name": "Submit FOIA or Privacy Act Request",
            "description": {
              "content": "Create a new Freedom of Information Act (FOIA) or Privacy Act (PA) request for Alien File material. The request can be submitted about or on behalf of the subject of record. A unique Request Number is returned upon successful creation, which can be used to track the request status.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "requests"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "scope",
                  "value": "read:foia-requests write:foia-requests"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://api-int.uscis.gov/oauth/accesstoken"
                },
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"requestType\": \"<string>\",\n  \"subjectFirstName\": \"<string>\",\n  \"subjectLastName\": \"<string>\",\n  \"requesterName\": \"<string>\",\n  \"requesterEmail\": \"<email>\",\n  \"requesterType\": \"<string>\",\n  \"descriptionOfRecords\": \"<string>\",\n  \"subjectMiddleName\": \"<string>\",\n  \"subjectDateOfBirth\": \"<date>\",\n  \"subjectCountryOfBirth\": \"<string>\",\n  \"subjectAlienNumber\": \"<string>\",\n  \"subjectReceiptNumber\": \"<string>\",\n  \"deliveryMethod\": \"email\",\n  \"feeWaiverRequest\": false,\n  \"expeditedProcessingRequest\": false,\n  \"expeditedProcessingJustification\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
