        {
          "id": "7db1e95a-8eb3-429d-9e64-f9efaccc2ed3",
          "name": "Get FOIA Request Status",
          "request": {
            "name": "Get FOIA Request Status",
            "description": {
              "content": "Check the current status of a submitted FOIA or Privacy Act request using the Request Number returned when the request was created. Returns the current processing status and any available updates.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "requests",
                ":requestNumber"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "requestNumber",
                  "description": "(Required) The FOIA request number returned when the request was submitted. Format: USCIS-YYYY-NNNNNN"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
